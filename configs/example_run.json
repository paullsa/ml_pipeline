{
    "run_name": "iris_baseline_v1",
    "data": {
        "raw_data_path": "data/raw/iris.csv",
        "target_column": "X",
        "exclude_columns": [],
        "test_size": 0.2,
        "random_state": 42
    },
    "model": {
        "type": "xgboost",
        "task": "classification",
        "hyperparameters": {
            "n_estimators": 100,
            "max_depth": 4,
            "learning_rate": 0.1
        }
    },
    "evaluation": {
        "metrics": ["accuracy", "f1"]
    }
}